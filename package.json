{
  "name": "rapitas",
  "version": "1.0.0",
  "description": "階層型タスク管理システム",
  "private": true,
  "scripts": {
    "predev": "node scripts/preflight-check.cjs",
    "dev": "concurrently --kill-others-on-fail \"npm run dev:backend\" \"npm run dev:frontend\" --names \"BACKEND,FRONTEND\" --prefix-colors \"cyan,magenta\"",
    "dev:skip-check": "concurrently --kill-others-on-fail \"npm run dev:backend\" \"npm run dev:frontend\" --names \"BACKEND,FRONTEND\" --prefix-colors \"cyan,magenta\"",
    "dev:backend": "cd rapitas-backend && bun run dev",
    "dev:backend:simple": "cd rapitas-backend && bun run dev:simple",
    "dev:frontend": "cd rapitas-frontend && cross-env pnpm run dev",
    "dev:tauri": "cd rapitas-desktop && node scripts/dev.js",
    "dev:tauri:watch": "cd rapitas-desktop && node scripts/dev.js --watch",
    "tauri": "cd rapitas-desktop && pnpm run tauri dev",
    "tauri:build": "cd rapitas-desktop && pnpm run tauri build",
    "check": "node scripts/preflight-check.cjs",
    "check:commit": "node scripts/pre-commit-check.cjs",
    "build:web": "node scripts/switch-to-postgres.cjs && cd rapitas-frontend && pnpm run build",
    "install:all": "cd rapitas-backend && bun install && cd ../rapitas-frontend && pnpm install && cd ../rapitas-desktop && pnpm install",
    "test:all": "concurrently \"cd rapitas-backend && bun test\" \"cd rapitas-frontend && pnpm test\" --names \"BE-TEST,FE-TEST\" --prefix-colors \"cyan,magenta\"",
    "lint:all": "concurrently \"cd rapitas-backend && bun run lint\" \"cd rapitas-frontend && pnpm run lint\" --names \"BE-LINT,FE-LINT\" --prefix-colors \"cyan,magenta\"",
    "lint:fix": "cd rapitas-frontend && npx prettier --write \"src/**/*.{ts,tsx}\" && npx eslint --fix \"src/**/*.{ts,tsx}\" && cd ../rapitas-backend && npx prettier --write \"**/*.ts\"",
    "prisma:migrate": "cd rapitas-backend && npx prisma migrate dev",
    "prisma:push": "cd rapitas-backend && npx prisma db push",
    "prisma:generate": "cd rapitas-backend && npx prisma generate",
    "prisma:studio": "cd rapitas-backend && npx prisma studio",
    "version:sync": "node scripts/sync-version.cjs",
    "version:check": "node scripts/sync-version.cjs --check",
    "env:check": "node scripts/verify-env.cjs",
    "check:files": "node scripts/check-large-files.cjs",
    "check:files:warn": "node scripts/check-large-files.cjs --warn-only",
    "check:todos": "node scripts/check-todos.cjs",
    "check:todos:ci": "node scripts/check-todos.cjs --max-hack 14 --max-fixme 1",
    "snapshot": "node scripts/snapshot-bottlenecks.cjs",
    "snapshot:write": "node scripts/snapshot-bottlenecks.cjs --write",
    "snapshot:diff": "node scripts/snapshot-bottlenecks.cjs --diff",
    "baseline:files": "node scripts/check-large-files.cjs --update-baseline",
    "clean": "node scripts/clean.cjs",
    "clean:deep": "node scripts/clean.cjs --deep",
    "clean:dry": "node scripts/clean.cjs --dry-run",
    "perf": "node scripts/measure-performance.cjs",
    "perf:ci": "node scripts/measure-performance.cjs --ci",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "concurrently": "^9.1.2",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "get-port-cli": "^3.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1"
  },
  "lint-staged": {
    "rapitas-frontend/src/**/*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix --no-warn-ignored --max-warnings=9999 --config rapitas-frontend/eslint.config.mjs"
    ],
    "rapitas-backend/**/*.ts": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "zustand": "^5.0.12"
  }
}
