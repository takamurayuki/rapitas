{
  "$schema": "https://schema.tauri.app/config/2",
  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand": "",
    "frontendDist": "../public"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "../../rapitas-backend/prisma/migrations/**/*",
      "../../rapitas-backend/prisma/schema.prisma",
      {
        "path": "binaries/rapitas-backend*",
        "target": "rapitas-backend"
      }
    ]
  },
  "plugins": {
    "shell": {
      "open": true,
      "sidecar": true,
      "scope": [
        {
          "name": "binaries/rapitas-backend",
          "sidecar": true,
          "args": true
        }
      ]
    }
  }
}
