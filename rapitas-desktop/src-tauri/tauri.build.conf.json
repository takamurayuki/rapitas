{
  "$schema": "https://schema.tauri.app/config/2",
  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand": "",
    "frontendDist": "../public"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      {
        "path": "../../rapitas-backend/prisma/migrations",
        "target": "migrations"
      },
      {
        "path": "../../rapitas-backend/prisma/schema.prisma",
        "target": "schema.prisma"
      }
    ],
    "externalBin": [
      "binaries/rapitas-backend"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
