{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Rapitas",
  "version": "1.0.0",
  "identifier": "com.rapitas.app",
  "build": {
    "beforeBuildCommand": "node scripts/build-all.js",
    "beforeDevCommand": "node scripts/dev.js",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../../rapitas-frontend/.next-tauri"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Rapitas - AI Task Manager",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm", "nsis", "msi", "dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": [
          "libgtk-3-0",
          "libwebkit2gtk-4.1-0",
          "libappindicator3-1",
          "librsvg2-2"
        ]
      },
      "rpm": {
        "depends": ["gtk3", "webkit2gtk4.1", "libappindicator-gtk3", "librsvg2"]
      },
      "appimage": {
        "bundleMediaFramework": true,
        "files": {}
      }
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "wix": null,
      "nsis": {
        "installMode": "both"
      }
    },
    "externalBin": [],
    "resources": [
      "Rapitas.desktop",
      "binaries/rapitas-backend-*.exe",
      "binaries/rapitas-backend-*"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
