{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Rapitas",
  "version": "1.0.0",
  "identifier": "com.rapitas.app",
  "build": {
    "beforeBuildCommand": "node scripts/build-all.js",
    "beforeDevCommand": "node scripts/dev.js",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../../rapitas-frontend/.next-tauri"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Rapitas - AI Task Manager",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/rapitas-backend"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
