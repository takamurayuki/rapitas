    "@lucide/lab": "^0.1.2",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/recharts": "^2.0.1",
    "framer-motion": "^12.34.2",
    "highlight.js": "^11.11.1",
    "lucide-react": "^0.562.0",
    "next": "16.0.1",
    "next-intl": "^4.8.3",
    "react": "19.2.0",
