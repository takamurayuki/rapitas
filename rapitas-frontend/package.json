{
  "name": "rapitas-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev-with-cache-check.js",
    "dev:clean": "cross-env FORCE_CLEAN=true node scripts/dev-with-cache-check.js",
    "dev:no-check": "next dev",
    "build": "next build",
    "build:tauri": "node scripts/prepare-tauri-build.js backup && cross-env TAURI_BUILD=true next build && node scripts/prepare-tauri-build.js restore",
    "build:tauri:ci": "cross-env TAURI_BUILD=true next build && node scripts/prepare-tauri-build.js restore",
    "build:tauri:no-restore": "node scripts/prepare-tauri-build.js backup && cross-env TAURI_BUILD=true next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prettier": "prettier",
    "prettier:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,css,md}\"",
    "prettier:write": "prettier --write \"src/**/*.{ts,tsx,js,jsx,css,md}\"",
    "clean": "rimraf .next node_modules/.cache",
    "clean:all": "rimraf .next node_modules/.cache node_modules",
    "reinstall": "pnpm run clean:all && pnpm install"
  },
  "dependencies": {
    "@hello-pangea/dnd": "^18.0.1",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/recharts": "^2.0.1",
    "dompurify": "^3.4.2",
    "framer-motion": "^12.38.0",
    "highlight.js": "^11.11.1",
    "lucide-react": "^1.14.0",
    "next": "16.2.4",
    "next-intl": "^4.11.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "react-toastify": "^11.1.0",
    "recharts": "^3.8.1",
    "rehype-highlight": "^7.0.2",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "swr": "^2.4.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@storybook/addon-essentials": "8.6.14",
    "@storybook/nextjs": "^8.6.18",
    "@storybook/react": "^8.6.18",
    "@storybook/react-dom-shim": "8.6.14",
    "@tailwindcss/postcss": "^4.2.4",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/dompurify": "^3.2.0",
    "@types/node": "^20.19.39",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "4.0.18",
    "baseline-browser-mapping": "^2.10.25",
    "cross-env": "^7.0.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.0.1",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "storybook": "^8.6.18",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.9.3",
    "vite": "^7.3.2",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "overrides": {
      "lucide-react": "^1.11.0",
      "vite": "^7.3.2"
    }
  }
}
