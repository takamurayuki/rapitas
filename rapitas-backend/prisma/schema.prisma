// Prisma schema for PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  color       String   @default("#6366F1")
  icon        String?
  isDefault   Boolean  @default(false)
  mode        String   @default("both") // "development", "learning", "both"
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  themes      Theme[]
}

model Theme {
  id               Int            @id @default(autoincrement())
  name             String
  description      String?
  color            String         @default("#8B5CF6")
  icon             String?
  isDefault        Boolean        @default(false)
  isDevelopment    Boolean        @default(false)
  repositoryUrl    String?
  workingDirectory String?
  defaultBranch    String?        @default("main")
  sortOrder        Int            @default(0)
  categoryId       Int?
  category         Category?      @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  tasks            Task[]
  templates        TaskTemplate[]
  userBehaviors    UserBehavior[]
  taskPatterns     TaskPattern[]
  behaviorSummaries UserBehaviorSummary[]
}

model Project {
  id          Int         @id @default(autoincrement())
  name        String
  description String?
  color       String      @default("#3B82F6")
  icon        String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  tasks       Task[]
  milestones  Milestone[]
}

model Milestone {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  dueDate     DateTime?
  projectId   Int
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks       Task[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Task {
  id                    Int           @id @default(autoincrement())
  title                 String
  description           String?
  status                String        @default("todo")
  priority              String        @default("medium")
  labels                String        @default("[]") // JSON array stored as string
  estimatedHours        Float?
  actualHours           Float?
  dueDate               DateTime?
  subject               String?
  startedAt             DateTime?
  completedAt           DateTime?
  parentId              Int?
  parent                Task?         @relation("TaskSubtasks", fields: [parentId], references: [id], onDelete: Cascade)
  subtasks              Task[]        @relation("TaskSubtasks")
  themeId               Int?
  theme                 Theme?        @relation(fields: [themeId], references: [id], onDelete: SetNull)
  projectId             Int?
  project               Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  milestoneId           Int?
  milestone             Milestone?    @relation(fields: [milestoneId], references: [id], onDelete: SetNull)
  examGoalId            Int?
  examGoal              ExamGoal?     @relation(fields: [examGoalId], references: [id], onDelete: SetNull)
  timeEntries           TimeEntry[]
  pomodoroSessions      PomodoroSession[]
  comments              Comment[]
  activityLogs          ActivityLog[]
  taskLabels            TaskLabel[]
  resources             Resource[]
  isDeveloperMode       Boolean       @default(false)
  isAiTaskAnalysis      Boolean       @default(false)
  agentGenerated        Boolean       @default(false)
  agentExecutable       Boolean       @default(false)
  executionInstructions String?
  developerModeConfig   DeveloperModeConfig?
  taskAnalysisConfig    TaskAnalysisConfig?
  agentExecutionConfig  AgentExecutionConfig?
  prompts               TaskPrompt[]
  githubIssueId         Int?
  githubPrId            Int?
  autoExecutable        Boolean       @default(false)
  requireApproval       String        @default("always")
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  userBehaviors         UserBehavior[]
  workingDirectory      String?
  workflowStatus        String?
  // Workflow flexibility system fields
  workflowMode          String?   @default("comprehensive") // "lightweight", "standard", "comprehensive"
  complexityScore       Float?    // Auto-determined complexity score (0-100)
  workflowModeOverride  Boolean   @default(false) // Whether mode was manually changed
  autoApprovePlan       Boolean   @default(false) // Whether to auto-approve plan.md at task level
  workflowLearningRecords WorkflowLearningRecord[]

  @@index([status])
  @@index([themeId])
  @@index([status, themeId])
  @@index([parentId])
  @@index([dueDate])
}

model TimeEntry {
  id            Int      @id @default(autoincrement())
  taskId        Int
  task          Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  duration      Float
  breakDuration Float?   @default(0)
  note          String?
  startedAt     DateTime
  endedAt       DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model PomodoroSession {
  id              Int       @id @default(autoincrement())
  taskId          Int?
  task            Task?     @relation(fields: [taskId], references: [id], onDelete: SetNull)
  status          String    @default("active") // active, paused, completed, cancelled
  type            String    @default("work")   // work, short_break, long_break
  duration        Int       // total duration in seconds
  elapsed         Int       @default(0)        // elapsed seconds before current active period
  startedAt       DateTime  @default(now())
  pausedAt        DateTime?
  completedAt     DateTime?
  completedPomodoros Int    @default(0)         // count of completed work sessions in series
  note            String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([status])
  @@index([taskId])
}

model Comment {
  id        Int       @id @default(autoincrement())
  taskId    Int
  task      Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  content   String
  parentId  Int?
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[] @relation("CommentReplies")
  // Many-to-many links between comments
  linksFrom CommentLink[] @relation("CommentLinkFrom")
  linksTo   CommentLink[] @relation("CommentLinkTo")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

// Many-to-many relation table for linking comments
model CommentLink {
  id            Int      @id @default(autoincrement())
  fromCommentId Int
  toCommentId   Int
  fromComment   Comment  @relation("CommentLinkFrom", fields: [fromCommentId], references: [id], onDelete: Cascade)
  toComment     Comment  @relation("CommentLinkTo", fields: [toCommentId], references: [id], onDelete: Cascade)
  label         String?  // Optional label for the link (e.g., "related", "reference", "supplement")
  createdAt     DateTime @default(now())

  @@unique([fromCommentId, toCommentId])
  @@index([fromCommentId])
  @@index([toCommentId])
}

model ActivityLog {
  id        Int      @id @default(autoincrement())
  taskId    Int?
  task      Task?    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  projectId Int?
  action    String
  changes   String?  // JSON stored as string
  metadata  String?  // JSON stored as string
  createdAt DateTime @default(now())
}

// Records user behavior data
model UserBehavior {
  id              Int       @id @default(autoincrement())
  userId          Int       @default(1) // For future multi-user support
  actionType      String    // task_created, task_completed, task_started, task_updated, theme_selected, label_used, etc.
  taskId          Int?
  task            Task?     @relation(fields: [taskId], references: [id], onDelete: SetNull)
  themeId         Int?
  theme           Theme?    @relation(fields: [themeId], references: [id], onDelete: SetNull)
  context         String?   // JSON: Detailed behavior context (time of day, day of week, surrounding actions, etc.)
  metadata        String?   // JSON: Other metadata
  createdAt       DateTime  @default(now())

  @@index([userId, actionType])
  @@index([createdAt])
}

// Records task completion patterns
model TaskPattern {
  id                    Int       @id @default(autoincrement())
  userId                Int       @default(1)
  themeId              Int?
  theme                Theme?    @relation(fields: [themeId], references: [id], onDelete: SetNull)
  taskTitle            String
  taskDescription      String?
  priority             String
  estimatedHours       Float?
  actualHours          Float?
  completionRate       Float?    // Completion rate (0-1)
  averageTimeToStart   Float?    // Average time from creation to start (hours)
  averageTimeToComplete Float?   // Average time from start to completion (hours)
  frequency            Int       @default(1) // Number of occurrences of this pattern
  labelIds             String    @default("[]") // JSON array of label IDs
  lastOccurrence       DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@unique([userId, taskTitle, themeId])
  @@index([userId, themeId])
}

// Aggregated data for AI learning
model UserBehaviorSummary {
  id                    Int       @id @default(autoincrement())
  userId                Int       @default(1)
  periodType           String    // daily, weekly, monthly
  periodStart          DateTime
  periodEnd            DateTime
  themeId              Int?
  theme                Theme?    @relation(fields: [themeId], references: [id], onDelete: SetNull)
  totalTasks           Int       @default(0)
  completedTasks       Int       @default(0)
  averageCompletionTime Float?    // Average completion time (hours)
  preferredTimeOfDay   String?   // morning, afternoon, evening, night
  preferredDayOfWeek   String?   // JSON array: ["monday", "tuesday", ...]
  mostUsedLabels       String    @default("[]") // JSON array of label IDs with counts
  taskPriorities       String    @default("{}") // JSON: {"urgent": 10, "high": 20, ...}
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@unique([userId, periodType, periodStart, themeId])
  @@index([userId, periodType, periodStart])
}

model Label {
  id          Int         @id @default(autoincrement())
  name        String
  description String?
  color       String      @default("#6366F1")
  icon        String?
  sortOrder   Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  tasks       TaskLabel[]
}

model TaskLabel {
  id        Int      @id @default(autoincrement())
  taskId    Int
  labelId   Int
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  label     Label    @relation(fields: [labelId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([taskId, labelId])
}

model ExamGoal {
  id            Int       @id @default(autoincrement())
  name          String
  description   String?
  examDate      DateTime
  targetScore   String?
  color         String    @default("#10B981")
  icon          String?
  isCompleted   Boolean   @default(false)
  actualScore   String?
  tasks         Task[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model StudyStreak {
  id              Int      @id @default(autoincrement())
  date            DateTime @unique
  studyMinutes    Int      @default(0)
  tasksCompleted  Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Learning goals (flexible goal setting → automatic task generation)
model LearningGoal {
  id              Int       @id @default(autoincrement())
  title           String    // Learning goal title (e.g., "Become a red coder in competitive programming")
  description     String?   // Detailed description of the goal
  currentLevel    String?   // Current level (e.g., "brown coder", "1 year of professional experience")
  targetLevel     String?   // Target level (e.g., "red coder", "10 million yen salary")
  deadline        DateTime? // Achievement deadline
  dailyHours      Float     @default(2) // Daily study hours
  categoryId      Int?      // Associated category
  themeId         Int?      // ID of the auto-generated theme
  status          String    @default("active") // active, completed, archived
  generatedPlan   String?   // JSON of the generated learning plan
  isApplied       Boolean   @default(false) // Whether applied as tasks
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Habit {
  id            Int           @id @default(autoincrement())
  name          String
  description   String?
  icon          String?
  color         String        @default("#10B981")
  frequency     String        @default("daily")
  targetCount   Int           @default(1)
  isActive      Boolean       @default(true)
  logs          HabitLog[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model HabitLog {
  id        Int      @id @default(autoincrement())
  habitId   Int
  habit     Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)
  date      DateTime
  count     Int      @default(1)
  note      String?
  createdAt DateTime @default(now())

  @@unique([habitId, date])
}

model DailyScheduleBlock {
  id          Int      @id @default(autoincrement())
  label       String
  startTime   String   // "HH:mm" format (e.g. "07:00")
  endTime     String   // "HH:mm" format (e.g. "08:00")
  color       String   @default("#3B82F6")
  icon        String?
  category    String   @default("other") // sleep, work, exercise, meal, commute, study, hobby, other
  isNotify    Boolean  @default(false)   // send PC notification at startTime
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Resource {
  id          Int      @id @default(autoincrement())
  taskId      Int?
  task        Task?    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  title       String
  url         String?
  type        String
  description String?
  // File upload fields
  filePath    String?
  fileName    String?
  fileSize    Int?
  mimeType    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FlashcardDeck {
  id              Int         @id @default(autoincrement())
  name            String
  description     String?
  color           String      @default("#3B82F6")
  taskId          Int?
  learningGoalId  Int?
  phaseIndex      Int?
  cards           Flashcard[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model Flashcard {
  id          Int           @id @default(autoincrement())
  deckId      Int
  deck        FlashcardDeck @relation(fields: [deckId], references: [id], onDelete: Cascade)
  front       String
  back        String
  nextReview  DateTime?
  interval    Int           @default(1)
  easeFactor  Float         @default(2.5)
  reviewCount Int           @default(0)
  // FSRS algorithm fields
  stability   Float         @default(0)
  difficulty  Float         @default(0)
  state       Int           @default(0) // 0=New, 1=Learning, 2=Review, 3=Relearning
  lapses      Int           @default(0)
  lastReview  DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model TaskTemplate {
  id            Int      @id @default(autoincrement())
  name          String
  description   String?
  category      String
  templateData  String   // JSON stored as string
  isPublic      Boolean  @default(false)
  useCount      Int      @default(0)
  themeId       Int?
  theme         Theme?   @relation(fields: [themeId], references: [id], onDelete: SetNull)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model DeveloperModeConfig {
  id                Int       @id @default(autoincrement())
  taskId            Int       @unique
  task              Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  isEnabled         Boolean   @default(true)
  autoApprove       Boolean   @default(false)
  notifyInApp       Boolean   @default(true)
  maxSubtasks       Int       @default(10)
  priority          String    @default("balanced")
  requireApproval   String    @default("always")
  autoExecuteOn     String    @default("[]") // JSON array stored as string
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  agentSessions     AgentSession[]
  approvalRequests  ApprovalRequest[]
}

model AgentSession {
  id                Int       @id @default(autoincrement())
  configId          Int
  config            DeveloperModeConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  status            String    @default("pending")
  mode              String?   // セッションモード: "workflow-researcher", "workflow-planner" etc.
  startedAt         DateTime?
  completedAt       DateTime?
  lastActivityAt    DateTime  @default(now())
  totalTokensUsed   Int       @default(0)
  errorMessage      String?
  metadata          String?   // JSON stored as string
  branchName        String?   // Git branch name for the execution session
  worktreePath      String?   // Absolute path to git worktree (non-null during execution)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  agentActions      AgentAction[]
  agentExecutions   AgentExecution[]
}

model AgentAction {
  id                Int       @id @default(autoincrement())
  sessionId         Int
  session           AgentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  actionType        String
  targetTaskId      Int?
  input             String?   // JSON stored as string
  output            String?   // JSON stored as string
  tokensUsed        Int       @default(0)
  durationMs        Int?
  status            String    @default("success")
  errorMessage      String?
  createdAt         DateTime  @default(now())
}

model ApprovalRequest {
  id                Int       @id @default(autoincrement())
  configId          Int
  config            DeveloperModeConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  requestType       String
  title             String
  description       String?
  proposedChanges   String    // JSON stored as string
  status            String    @default("pending")
  expiresAt         DateTime?
  approvedAt        DateTime?
  rejectedAt        DateTime?
  rejectionReason   String?
  notificationSent  Boolean   @default(false)
  executionType     String?
  estimatedChanges  String?   // JSON stored as string
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model Notification {
  id                Int       @id @default(autoincrement())
  type              String
  title             String
  message           String
  link              String?
  isRead            Boolean   @default(false)
  readAt            DateTime?
  metadata          String?   // JSON stored as string
  createdAt         DateTime  @default(now())
}

model UserSettings {
  id                          Int       @id @default(autoincrement())
  developerModeDefault        Boolean   @default(false)
  aiTaskAnalysisDefault       Boolean   @default(false)
  autoResumeInterruptedTasks  Boolean   @default(false)
  autoExecuteAfterCreate      Boolean   @default(false)
  autoGenerateTitle           Boolean   @default(false)
  autoGenerateTitleDelay      Int       @default(3)       // Wait time in seconds before auto-generating title
  autoCreateAfterTitleGeneration Boolean @default(false) // Auto-create after title generation
  autoFetchTaskSuggestions    Boolean   @default(true)  // Auto-fetch AI suggestions when theme is selected
  defaultCategoryId           Int?      // Default selected category
  activeMode                  String    @default("both") // "development", "learning", "both"
  claudeApiKeyEncrypted       String?
  chatgptApiKeyEncrypted      String?
  geminiApiKeyEncrypted       String?
  claudeDefaultModel          String?
  chatgptDefaultModel         String?
  geminiDefaultModel          String?
  ollamaUrl                   String?   @default("http://localhost:11434")
  ollamaDefaultModel          String?   @default("gemma3:4b")
  titleGenerationProvider     String?   @default("ollama") // Title generation provider (ollama=local free AI)
  defaultAiProvider           String?   @default("claude")
  autoApprovePlan             Boolean   @default(false) // Whether to auto-approve when saving plan.md
  autoApproveSubtaskPlan      Boolean   @default(true)  // Auto-approve subtask plan.md (default ON)
  autoComplexityAnalysis      Boolean   @default(false) // Whether to enable automatic complexity analysis
  createdAt                   DateTime  @default(now())
  updatedAt                   DateTime  @updatedAt
}

model AIAgentConfig {
  id              Int       @id @default(autoincrement())
  agentType       String
  name            String
  apiKeyEncrypted String?
  endpoint        String?
  modelId         String?
  version         String?   // Agent version (e.g., "1.0.0")
  latestVersion   String?   // Latest available version
  isDefault       Boolean   @default(false)
  isActive        Boolean   @default(true)
  isInstalled     Boolean   @default(true)  // Whether installed
  installPath     String?   // Installation path
  capabilities    String    @default("{}") // JSON stored as string
  metadata        String    @default("{}") // Version-specific metadata (JSON)
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  executions              AgentExecution[]
  taskAnalysisConfigs     TaskAnalysisConfig[]
  agentExecutionConfigs   AgentExecutionConfig[]
  workflowRoles           WorkflowRoleConfig[]
}

model AgentExecution {
  id                Int       @id @default(autoincrement())
  sessionId         Int
  session           AgentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  agentConfigId     Int?
  agentConfig       AIAgentConfig? @relation(fields: [agentConfigId], references: [id], onDelete: SetNull)
  command           String
  status            String    @default("pending")
  output            String?
  artifacts         String?   // JSON stored as string
  startedAt         DateTime?
  completedAt       DateTime?
  tokensUsed        Int       @default(0)
  executionTimeMs   Int?
  errorMessage      String?
  question          String?
  questionType      String?
  questionDetails   String?   // JSON stored as string
  claudeSessionId   String?   // Claude Code CLI session ID for --resume
  createdAt         DateTime  @default(now())
  gitCommits        GitCommit[]
  executionLogs     AgentExecutionLog[]
}

model AgentExecutionLog {
  id                Int       @id @default(autoincrement())
  executionId       Int
  execution         AgentExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  logChunk          String
  logType           String    @default("stdout") // stdout, stderr, system
  sequenceNumber    Int
  timestamp         DateTime  @default(now())
  createdAt         DateTime  @default(now())

  @@index([executionId, sequenceNumber])
}

model GitHubIntegration {
  id                Int       @id @default(autoincrement())
  repositoryUrl     String    @unique
  repositoryName    String
  ownerName         String
  accessTokenEnc    String?
  webhookSecret     String?
  isActive          Boolean   @default(true)
  syncIssues        Boolean   @default(true)
  syncPullRequests  Boolean   @default(true)
  autoLinkTasks     Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  pullRequests      GitHubPullRequest[]
  issues            GitHubIssue[]
}

model GitHubPullRequest {
  id                Int       @id @default(autoincrement())
  integrationId     Int
  integration       GitHubIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  prNumber          Int
  title             String
  body              String?
  state             String
  headBranch        String
  baseBranch        String
  authorLogin       String
  url               String
  linkedTaskId      Int?
  lastSyncedAt      DateTime
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  reviews           GitHubPRReview[]
  comments          GitHubPRComment[]
  @@unique([integrationId, prNumber])
}

model GitHubPRReview {
  id                Int       @id @default(autoincrement())
  pullRequestId     Int
  pullRequest       GitHubPullRequest @relation(fields: [pullRequestId], references: [id], onDelete: Cascade)
  reviewId          Int
  state             String
  body              String?
  authorLogin       String
  submittedAt       DateTime
  createdAt         DateTime  @default(now())
}

model GitHubPRComment {
  id                Int       @id @default(autoincrement())
  pullRequestId     Int
  pullRequest       GitHubPullRequest @relation(fields: [pullRequestId], references: [id], onDelete: Cascade)
  commentId         Int
  body              String
  path              String?
  line              Int?
  authorLogin       String
  isFromRapitas     Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model GitHubIssue {
  id                Int       @id @default(autoincrement())
  integrationId     Int
  integration       GitHubIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  issueNumber       Int
  title             String
  body              String?
  state             String
  labels            String    @default("[]") // JSON array stored as string
  authorLogin       String
  url               String
  linkedTaskId      Int?
  lastSyncedAt      DateTime
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  @@unique([integrationId, issueNumber])
}

model GitCommit {
  id                Int       @id @default(autoincrement())
  executionId       Int
  execution         AgentExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  commitHash        String
  message           String
  branch            String
  filesChanged      Int       @default(0)
  additions         Int       @default(0)
  deletions         Int       @default(0)
  createdAt         DateTime  @default(now())
}

model FavoriteDirectory {
  id          Int       @id @default(autoincrement())
  path        String    @unique
  name        String?
  isGitRepo   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model TaskPrompt {
  id                  Int       @id @default(autoincrement())
  taskId              Int
  task                Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  name                String?
  originalDescription String?
  optimizedPrompt     String
  structuredSections  String?   // JSON stored as string
  qualityScore        Int?
  isActive            Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([taskId])
}

// Task analysis settings (AI analysis parameters per task)
model TaskAnalysisConfig {
  id                    Int       @id @default(autoincrement())
  taskId                Int       @unique
  task                  Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)

  // Analysis parameters
  analysisDepth         String    @default("standard") // quick, standard, deep
  maxSubtasks           Int       @default(10)
  priorityStrategy      String    @default("balanced") // aggressive, balanced, conservative
  includeEstimates      Boolean   @default(true)
  includeDependencies   Boolean   @default(true)
  includeTips           Boolean   @default(true)

  // Model and provider settings
  agentConfigId         Int?
  agentConfig           AIAgentConfig? @relation(fields: [agentConfigId], references: [id], onDelete: SetNull)
  modelOverride         String?   // Override with specific model ID
  maxTokens             Int?      // Maximum tokens for analysis
  temperature           Float?    // Analysis creativity parameter (0.0-1.0)

  // Prompt strategy
  promptStrategy        String    @default("auto") // auto, detailed, concise, custom
  customPromptTemplate  String?   // Custom prompt template
  contextInstructions   String?   // Additional context instructions

  // Automation settings
  autoApproveSubtasks   Boolean   @default(false)
  autoOptimizePrompt    Boolean   @default(false)
  notifyOnComplete      Boolean   @default(true)

  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([taskId])
}

// Agent execution settings (execution parameters per task)
model AgentExecutionConfig {
  id                    Int       @id @default(autoincrement())
  taskId                Int       @unique
  task                  Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)

  // Agent selection
  agentConfigId         Int?
  agentConfig           AIAgentConfig? @relation(fields: [agentConfigId], references: [id], onDelete: SetNull)

  // Execution environment settings
  workingDirectory      String?   // Working directory override
  timeoutMs             Int       @default(900000) // Execution timeout (default 15 minutes)
  maxRetries            Int       @default(0)

  // Git settings
  branchStrategy        String    @default("auto") // auto, manual, none
  branchPrefix          String    @default("feature/")
  autoCommit            Boolean   @default(false)
  autoCreatePR          Boolean   @default(false)
  autoMergePR           Boolean   @default(false)
  mergeCommitThreshold  Int       @default(5)
  targetBranch          String    @default("develop") // Target branch for PR creation and merging

  // Execution control
  requireApproval       String    @default("always") // always, major_only, never
  autoExecuteOnAnalysis Boolean   @default(false) // Auto-execute after analysis completion
  parallelExecution     Boolean   @default(false) // Parallel execution of subtasks
  maxConcurrentAgents   Int       @default(3)

  // Prompt settings
  useOptimizedPrompt    Boolean   @default(true)
  additionalInstructions String?  // Additional instructions

  // Code review settings
  autoCodeReview        Boolean   @default(true)
  reviewScope           String    @default("changes") // changes, full, none

  // Notification settings
  notifyOnStart         Boolean   @default(true)
  notifyOnComplete      Boolean   @default(true)
  notifyOnError         Boolean   @default(true)
  notifyOnQuestion      Boolean   @default(true)

  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([taskId])
}

// System prompt management (manage hardcoded prompts in DB)
model SystemPrompt {
  id          Int       @id @default(autoincrement())
  key         String    @unique   // Unique key (e.g., "task_analysis", "prompt_optimization")
  name        String              // Display name
  description String?             // Prompt description
  content     String              // Prompt content
  category    String    @default("general") // Category (general, analysis, optimization, agent, chat)
  isActive    Boolean   @default(true)
  isDefault   Boolean   @default(true) // Whether this is the default prompt
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([key])
  @@index([category])
}

// Schedule event type enum
enum ScheduleEventType {
  GENERAL     // General schedule
  PAID_LEAVE  // Paid leave
}

// Schedule events (calendar schedule with reminder notifications)
model ScheduleEvent {
  id              Int       @id @default(autoincrement())
  title           String
  description     String?
  startAt         DateTime
  endAt           DateTime?
  isAllDay        Boolean   @default(false)
  color           String    @default("#6366F1")
  reminderMinutes Int?      // How many minutes before reminder notification (null=no reminder)
  reminderSentAt  DateTime? // Reminder sent date and time
  taskId          Int?
  type            ScheduleEventType @default(GENERAL) // Schedule type
  userId          String    @default("default") // User ID (for future multi-user support)
  // Recurring event support
  recurrenceRule  String?   // RRULE format: "FREQ=WEEKLY;BYDAY=MO,WE,FR"
  recurrenceEnd   DateTime? // Recurrence end date
  parentEventId   Int?      // Parent event ID for recurring events
  isRecurrenceException Boolean @default(false) // Individually edited recurring instance
  originalDate    DateTime? // Original recurring date (for exceptions)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([type])
  @@index([userId])
  @@index([startAt])
  @@index([parentEventId])
}

// Paid leave remaining days management
model PaidLeaveBalance {
  id                    Int       @id @default(autoincrement())
  userId                String    @unique @default("default")
  totalDays             Int       @default(20) // Annual granted days
  usedDays              Float     @default(0)  // Used days (Float for half-day leave support)
  remainingDays         Float     // Remaining days (actually stored, not a computed field)
  fiscalYear            Int       // Target fiscal year
  carryOverDays         Float     @default(0)  // Carried over days from previous year
  lastCalculatedAt      DateTime  @default(now()) // Last calculated date and time
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([userId, fiscalYear])
  @@index([fiscalYear])
}

// AI suggestion cache (saved per theme)
model TaskSuggestionCache {
  id                Int       @id @default(autoincrement())
  themeId           Int
  title             String
  description       String?
  priority          String    @default("medium")
  estimatedHours    Float?
  reason            String?
  category          String    @default("new") // recurring, extension, improvement, new
  labelIds          String    @default("[]") // JSON array stored as string
  analysis          String?   // AI analysis text (saved only in first record)
  completionCriteria String?  // Completion criteria
  measurableOutcome String?   // Measurable outcome
  dependencies      String?   // Prerequisites
  suggestedApproach String?   // Suggested approach
  createdAt         DateTime  @default(now())

  @@index([themeId])
}

// AI agent configuration change log
model AgentConfigAuditLog {
  id              Int       @id @default(autoincrement())
  agentConfigId   Int
  action          String    // create, update, delete, api_key_set, api_key_delete, test_connection
  changeDetails   String?   // JSON stored as string - what was changed
  previousValues  String?   // JSON stored as string - values before change
  newValues       String?   // JSON stored as string - values after change
  ipAddress       String?
  userAgent       String?
  createdAt       DateTime  @default(now())

  @@index([agentConfigId])
  @@index([createdAt])
}

// User authentication system
model User {
  id                Int       @id @default(autoincrement())
  username          String    @unique
  email             String?   @unique
  passwordHash      String?   // bcrypt hashed password (null for Google OAuth)
  displayName       String?
  role              String    @default("user") // admin, user
  isActive          Boolean   @default(true)
  emailVerified     Boolean   @default(false)
  lastLoginAt       DateTime?
  passwordResetToken String?
  passwordResetExpiresAt DateTime?
  // Google OAuth related fields
  provider          String    @default("local") // "local" or "google"
  providerId        String?   // Google User ID
  googleId          String?   @unique // Google-specific user ID
  avatar            String?   // Profile image URL
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  sessions          UserSession[]

  @@index([username])
  @@index([email])
  @@index([googleId])
}

// User session management (JWT Token management)
model UserSession {
  id              Int       @id @default(autoincrement())
  userId          Int
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionToken    String    @unique // JWT token or session identifier
  refreshToken    String?   @unique // Refresh token
  expiresAt       DateTime  // Session expiration
  lastAccessedAt  DateTime  @default(now())
  ipAddress       String?
  userAgent       String?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId])
  @@index([sessionToken])
  @@index([expiresAt])
}

model WorkflowRoleConfig {
  id              Int            @id @default(autoincrement())
  role            String         @unique
  agentConfigId   Int?
  agentConfig     AIAgentConfig? @relation(fields: [agentConfigId], references: [id], onDelete: SetNull)
  modelId         String?
  systemPromptKey String?
  isEnabled       Boolean        @default(true)
  metadata        String         @default("{}")
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

// Workflow mode settings (step definitions by mode)
model WorkflowModeConfig {
  id              Int       @id @default(autoincrement())
  mode            String    @unique // "lightweight", "standard", "comprehensive"
  name            String    // Display name (e.g., "lightweight", "standard", "detailed")
  description     String?   // Mode description
  stepDefinitions String    // JSON: Step definitions [{"status": "draft", "role": "implementer", "nextStatus": "in_progress"}]
  estimatedTime   Int       @default(60) // Expected execution time (minutes)
  isDefault       Boolean   @default(false)
  isEnabled       Boolean   @default(true)
  complexityMin   Float     @default(0)   // Minimum complexity for this mode to apply
  complexityMax   Float     @default(100) // Maximum complexity for this mode to apply
  autoSelectRules String    @default("{}") // JSON: Auto-selection rules
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([mode])
}

// ==========================================
// Memory/knowledge management system
// ==========================================

// Knowledge entries (core of memory system)
model KnowledgeEntry {
  id              Int       @id @default(autoincrement())
  sourceType      String    // "agent_execution" | "user_learning" | "task_pattern" | "distilled_procedure" | "consolidated"
  sourceId        String?
  title           String
  content         String
  contentHash     String
  category        String    @default("general") // "procedure" | "fact" | "pattern" | "preference" | "insight"
  tags            String    @default("[]")
  confidence      Float     @default(1.0)
  accessCount     Int       @default(0)
  lastAccessedAt  DateTime?
  forgettingStage String    @default("active") // "active" | "dormant" | "archived"
  decayScore      Float     @default(1.0)
  lastDecayAt     DateTime  @default(now())
  pinnedUntil     DateTime?
  validationStatus String   @default("pending") // "pending" | "validated" | "rejected" | "conflict"
  validatedAt     DateTime?
  validationMethod String?
  themeId         Int?
  taskId          Int?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  contradictions    KnowledgeContradiction[] @relation("EntryA")
  contradictedBy    KnowledgeContradiction[] @relation("EntryB")
  reconsolidations  KnowledgeReconsolidation[]

  @@index([sourceType, sourceId])
  @@index([category])
  @@index([forgettingStage])
  @@index([contentHash])
  @@index([themeId])
  @@index([decayScore])
}

// Timeline events (event log foundation of memory system)
model TimelineEvent {
  id              Int       @id @default(autoincrement())
  eventType       String    // "task_completed" | "agent_execution" | "knowledge_created" | "consolidation" | etc.
  actorType       String    @default("system") // "user" | "agent" | "system"
  actorId         String?
  payload         String    @default("{}") // JSON
  correlationId   String?   // For grouping related events
  createdAt       DateTime  @default(now())

  @@index([eventType])
  @@index([correlationId])
  @@index([createdAt])
}

// Consolidation execution records (daily knowledge integration process logs)
model ConsolidationRun {
  id                Int       @id @default(autoincrement())
  runDate           DateTime
  status            String    @default("running") // "running" | "completed" | "failed"
  entriesProcessed  Int       @default(0)
  entriesMerged     Int       @default(0)
  entriesCreated    Int       @default(0)
  errorMessage      String?
  durationMs        Int?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([runDate])
  @@index([status])
}

// Knowledge contradiction tracking (management of conflicting entry pairs)
model KnowledgeContradiction {
  id                Int       @id @default(autoincrement())
  entryAId          Int
  entryA            KnowledgeEntry @relation("EntryA", fields: [entryAId], references: [id], onDelete: Cascade)
  entryBId          Int
  entryB            KnowledgeEntry @relation("EntryB", fields: [entryBId], references: [id], onDelete: Cascade)
  contradictionType String    // "factual" | "procedural" | "preference"
  description       String?
  resolution        String?   // "keep_a" | "keep_b" | "merge" | "dismiss" | null (unresolved)
  resolvedAt        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([entryAId, entryBId])
  @@index([resolution])
}

// Knowledge re-consolidation records (knowledge update history based on prediction errors)
model KnowledgeReconsolidation {
  id                Int       @id @default(autoincrement())
  entryId           Int
  entry             KnowledgeEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  predictionError   String    // Prediction error content
  errorMagnitude    Float     // Error magnitude (0.0-1.0)
  previousContent   String    // Content before update
  newContent        String    // Content after update
  triggerSource     String?   // Re-consolidation trigger source
  createdAt         DateTime  @default(now())

  @@index([entryId])
  @@index([errorMagnitude])
}

// Memory system background job queue
model MemoryTaskQueue {
  id              Int       @id @default(autoincrement())
  taskType        String    // "embed" | "consolidate" | "validate" | "forget_sweep" | "distill" | "detect_contradiction"
  payload         String    @default("{}") // JSON
  priority        Int       @default(0)    // Higher value = higher priority
  status          String    @default("pending") // "pending" | "processing" | "completed" | "failed" | "dead_letter"
  attempts        Int       @default(0)
  maxAttempts     Int       @default(3)
  errorMessage    String?
  scheduledAt     DateTime  @default(now())
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([status, priority])
  @@index([taskType])
  @@index([scheduledAt])
}

// Memory journal entries (WAL crash resistance)
model MemoryJournalEntry {
  id              Int       @id @default(autoincrement())
  operationType   String    // "create" | "update" | "delete"
  targetTable     String    // "KnowledgeEntry" | "TimelineEvent" | etc.
  targetId        Int?
  payload         String    @default("{}") // JSON
  status          String    @default("pending") // "pending" | "committed" | "failed"
  errorMessage    String?
  createdAt       DateTime  @default(now())

  @@index([status])
  @@index([createdAt])
}

// Workflow orchestrator sessions
model OrchestraSession {
  id              Int       @id @default(autoincrement())
  status          String    @default("idle") // idle, conducting, paused, completed, error
  maxConcurrency  Int       @default(3)
  totalTasks      Int       @default(0)
  completedTasks  Int       @default(0)
  failedTasks     Int       @default(0)
  metadata        String    @default("{}") // JSON: configuration, stats
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  queueItems      WorkflowQueueItem[]

  @@index([status])
}

// Workflow queue items
model WorkflowQueueItem {
  id                Int       @id @default(autoincrement())
  taskId            Int
  orchestraSessionId Int?
  orchestraSession  OrchestraSession? @relation(fields: [orchestraSessionId], references: [id], onDelete: SetNull)
  priority          Int       @default(50) // 0-100, higher = more priority
  status            String    @default("queued") // queued, running, waiting_approval, completed, failed, cancelled
  currentPhase      String    @default("draft") // draft, research, plan, review, implement, verify
  dependencies      String    @default("[]") // JSON array of taskIds
  retryCount        Int       @default(0)
  maxRetries        Int       @default(3)
  errorMessage      String?
  result            String?   // JSON: execution result summary
  queuedAt          DateTime  @default(now())
  startedAt         DateTime?
  completedAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([taskId, orchestraSessionId])
  @@index([status, priority])
  @@index([orchestraSessionId])
  @@index([taskId])
}

// ============================================
// Self-Learning Agent Architecture
// ============================================

// Experiment log - record all task executions as experiments
model Experiment {
  id            Int       @id @default(autoincrement())
  taskId        Int?
  title         String
  status        String    @default("created") // created, researching, hypothesizing, planning, executing, evaluating, learning, completed, failed
  research      String    @default("{}") // JSON: collected information
  hypothesis    String?   // JSON: generated hypothesis
  plan          String?   // JSON: execution plan
  execution     String?   // JSON: execution details
  result        String?   // JSON: execution result
  evaluation    String?   // JSON: evaluation metrics
  learning      String?   // JSON: extracted learnings
  criticReviewId Int?
  confidence    Float     @default(0)
  duration      Int?      // milliseconds
  metadata      String    @default("{}") // JSON: additional context
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  hypotheses    Hypothesis[]
  criticReviews CriticReview[]
  episodes      EpisodeMemory[]
  promptEvolutions PromptEvolution[]

  @@index([taskId])
  @@index([status])
  @@index([createdAt])
}

// Hypothesis management - track solution hypotheses
model Hypothesis {
  id            Int       @id @default(autoincrement())
  experimentId  Int
  experiment    Experiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  content       String    // Hypothesis content
  reasoning     String?   // Hypothesis rationale
  status        String    @default("proposed") // proposed, testing, validated, invalidated, revised
  confidence    Float     @default(0.5) // 0-1.0
  priority      Int       @default(50) // 0-100
  testResult    String?   // JSON: test outcome
  parentId      Int?      // Source of hypothesis revision
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([experimentId])
  @@index([status])
}

// Critic review - results from independent evaluation agent
model CriticReview {
  id            Int       @id @default(autoincrement())
  experimentId  Int
  experiment    Experiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  phase         String    // hypothesis, plan, execution
  accuracy      Float     @default(0) // 0-1.0
  logic         Float     @default(0) // 0-1.0
  coverage      Float     @default(0) // 0-1.0
  overallScore  Float     @default(0) // 0-1.0
  feedback      String    // Review comments
  suggestions   String    @default("[]") // JSON: improvement suggestions
  issues        String    @default("[]") // JSON: detected issues
  createdAt     DateTime  @default(now())

  @@index([experimentId])
  @@index([phase])
}

// Knowledge graph nodes
model KnowledgeGraphNode {
  id            Int       @id @default(autoincrement())
  label         String    // Node name
  nodeType      String    // concept, problem, solution, technology, pattern
  description   String?
  properties    String    @default("{}") // JSON: additional properties
  weight        Float     @default(1.0) // importance weight
  accessCount   Int       @default(0)
  lastAccessedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  outEdges      KnowledgeGraphEdge[] @relation("EdgeFrom")
  inEdges       KnowledgeGraphEdge[] @relation("EdgeTo")

  @@unique([label, nodeType])
  @@index([nodeType])
  @@index([weight])
}

// Knowledge graph edges
model KnowledgeGraphEdge {
  id            Int       @id @default(autoincrement())
  fromNodeId    Int
  toNodeId      Int
  fromNode      KnowledgeGraphNode @relation("EdgeFrom", fields: [fromNodeId], references: [id], onDelete: Cascade)
  toNode        KnowledgeGraphNode @relation("EdgeTo", fields: [toNodeId], references: [id], onDelete: Cascade)
  edgeType      String    // related, causes, solves, requires, part_of, similar_to
  weight        Float     @default(1.0) // relationship strength
  metadata      String    @default("{}") // JSON
  createdAt     DateTime  @default(now())

  @@unique([fromNodeId, toNodeId, edgeType])
  @@index([fromNodeId])
  @@index([toNodeId])
  @@index([edgeType])
}

// Learning patterns - record success/failure patterns
model LearningPattern {
  id            Int       @id @default(autoincrement())
  patternType   String    // success_strategy, failure_pattern, optimization, anti_pattern
  category      String    // bug_fix, feature_implementation, refactoring, debugging, testing
  description   String
  conditions    String    @default("[]") // JSON: when this pattern applies
  actions       String    @default("[]") // JSON: recommended actions
  confidence    Float     @default(0.5) // 0-1.0
  occurrences   Int       @default(1) // how many times observed
  lastObserved  DateTime  @default(now())
  metadata      String    @default("{}") // JSON
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([patternType])
  @@index([category])
  @@index([confidence])
}

// Episodic memory - detailed experiment records
model EpisodeMemory {
  id            Int       @id @default(autoincrement())
  experimentId  Int
  experiment    Experiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  phase         String    // research, hypothesis, plan, execute, evaluate, learn
  content       String    // Episode content
  context       String    @default("{}") // JSON: environmental context
  outcome       String?   // success, failure, partial
  emotionalTag  String?   // surprising, expected, frustrating, satisfying
  importance    Float     @default(0.5) // 0-1.0
  createdAt     DateTime  @default(now())

  @@index([experimentId])
  @@index([phase])
  @@index([importance])
}

// Workflow learning records - actual workflow execution data from completed tasks
model WorkflowLearningRecord {
  id                    Int       @id @default(autoincrement())
  taskId                Int
  task                  Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  workflowMode          String    // Actually used mode: lightweight, standard, comprehensive
  predictedComplexity   Float?    // Predicted complexity score
  actualDurationMinutes Int?      // Actual execution time (minutes)
  estimatedDuration     Int?      // Estimated execution time (minutes)
  skippedPhases         String    @default("[]") // JSON: Skipped phases ["research", "plan"]
  phaseTimings          String    @default("{}") // JSON: Duration of each phase {"research": 5, "plan": 10, ...}
  outcome               String    @default("completed") // completed, failed, cancelled
  wasOverridden         Boolean   @default(false) // Whether mode was manually changed
  overriddenFrom        String?   // Mode before change
  categoryId            Int?
  themeId               Int?
  labels                String    @default("[]") // JSON: Task label name array
  titleKeywords         String    @default("[]") // JSON: Keywords extracted from title
  complexityFactors     String    @default("{}") // JSON: Complexity analysis element scores
  success               Boolean   @default(true) // Whether workflow succeeded
  createdAt             DateTime  @default(now())

  @@index([workflowMode])
  @@index([themeId])
  @@index([categoryId])
  @@index([outcome])
  @@index([createdAt])
}

// Workflow optimization rules - patterns extracted from learning data
model WorkflowOptimizationRule {
  id                Int       @id @default(autoincrement())
  ruleType          String    // skip_phase, downgrade_mode, upgrade_mode, adjust_time
  condition         String    // JSON: Rule application condition
  recommendation    String    // JSON: Recommended action
  confidence        Float     @default(0.5) // 0-1.0
  sampleSize        Int       @default(0) // Number of samples used for rule generation
  successRate       Float     @default(0) // Success rate of tasks matching this rule
  description       String    // Human-readable description
  isActive          Boolean   @default(true)
  lastEvaluated     DateTime  @default(now())
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([ruleType])
  @@index([confidence])
  @@index([isActive])
}

// Prompt evolution records - history of prompt improvements
model PromptEvolution {
  id            Int       @id @default(autoincrement())
  experimentId  Int?
  experiment    Experiment? @relation(fields: [experimentId], references: [id], onDelete: SetNull)
  category      String    // research, hypothesis, planning, execution, evaluation
  beforePrompt  String
  afterPrompt   String
  improvement   String?   // what was improved
  performanceDelta Float  @default(0) // -1.0 to 1.0
  createdAt     DateTime  @default(now())

  @@index([category])
  @@index([performanceDelta])
}

