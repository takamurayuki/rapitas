// SQLite version of Prisma schema for Tauri builds
// This schema is used when running as a desktop application

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Theme {
  id               Int            @id @default(autoincrement())
  name             String
  description      String?
  color            String         @default("#8B5CF6")
  icon             String?
  isDefault        Boolean        @default(false)
  isDevelopment    Boolean        @default(false)
  repositoryUrl    String?
  workingDirectory String?
  defaultBranch    String?        @default("main")
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  tasks            Task[]
  templates        TaskTemplate[]
}

model Project {
  id          Int         @id @default(autoincrement())
  name        String
  description String?
  color       String      @default("#3B82F6")
  icon        String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  tasks       Task[]
  milestones  Milestone[]
}

model Milestone {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  dueDate     DateTime?
  projectId   Int
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks       Task[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Task {
  id                    Int           @id @default(autoincrement())
  title                 String
  description           String?
  status                String        @default("todo")
  priority              String        @default("medium")
  labels                String        @default("[]") // JSON array stored as string
  estimatedHours        Float?
  actualHours           Float?
  dueDate               DateTime?
  subject               String?
  startedAt             DateTime?
  completedAt           DateTime?
  parentId              Int?
  parent                Task?         @relation("TaskSubtasks", fields: [parentId], references: [id], onDelete: Cascade)
  subtasks              Task[]        @relation("TaskSubtasks")
  themeId               Int?
  theme                 Theme?        @relation(fields: [themeId], references: [id], onDelete: SetNull)
  projectId             Int?
  project               Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  milestoneId           Int?
  milestone             Milestone?    @relation(fields: [milestoneId], references: [id], onDelete: SetNull)
  examGoalId            Int?
  examGoal              ExamGoal?     @relation(fields: [examGoalId], references: [id], onDelete: SetNull)
  timeEntries           TimeEntry[]
  comments              Comment[]
  activityLogs          ActivityLog[]
  taskLabels            TaskLabel[]
  resources             Resource[]
  isDeveloperMode       Boolean       @default(false)
  isAiTaskAnalysis      Boolean       @default(false)
  agentGenerated        Boolean       @default(false)
  agentExecutable       Boolean       @default(false)
  executionInstructions String?
  developerModeConfig   DeveloperModeConfig?
  prompts               TaskPrompt[]
  githubIssueId         Int?
  githubPrId            Int?
  autoExecutable        Boolean       @default(false)
  requireApproval       String        @default("always")
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
}

model TimeEntry {
  id            Int      @id @default(autoincrement())
  taskId        Int
  task          Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  duration      Float
  breakDuration Float?   @default(0)
  note          String?
  startedAt     DateTime
  endedAt       DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Comment {
  id        Int      @id @default(autoincrement())
  taskId    Int
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ActivityLog {
  id        Int      @id @default(autoincrement())
  taskId    Int?
  task      Task?    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  projectId Int?
  action    String
  changes   String?  // JSON stored as string
  metadata  String?  // JSON stored as string
  createdAt DateTime @default(now())
}

model Label {
  id          Int         @id @default(autoincrement())
  name        String
  description String?
  color       String      @default("#6366F1")
  icon        String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  tasks       TaskLabel[]
}

model TaskLabel {
  id        Int      @id @default(autoincrement())
  taskId    Int
  labelId   Int
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  label     Label    @relation(fields: [labelId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([taskId, labelId])
}

model ExamGoal {
  id            Int       @id @default(autoincrement())
  name          String
  description   String?
  examDate      DateTime
  targetScore   String?
  color         String    @default("#10B981")
  icon          String?
  isCompleted   Boolean   @default(false)
  actualScore   String?
  tasks         Task[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model StudyStreak {
  id              Int      @id @default(autoincrement())
  date            DateTime @unique
  studyMinutes    Int      @default(0)
  tasksCompleted  Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model StudyPlan {
  id            Int       @id @default(autoincrement())
  examGoalId    Int?
  subject       String
  prompt        String
  generatedPlan String    // JSON stored as string
  totalDays     Int
  startDate     DateTime
  endDate       DateTime
  isApplied     Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Achievement {
  id            Int                 @id @default(autoincrement())
  key           String              @unique
  name          String
  description   String
  icon          String
  color         String              @default("#FFD700")
  category      String
  condition     String              // JSON stored as string
  rarity        String              @default("common")
  unlockedBy    UserAchievement[]
  createdAt     DateTime            @default(now())
}

model UserAchievement {
  id            Int         @id @default(autoincrement())
  achievementId Int
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  unlockedAt    DateTime    @default(now())

  @@unique([achievementId])
}

model Habit {
  id            Int           @id @default(autoincrement())
  name          String
  description   String?
  icon          String?
  color         String        @default("#10B981")
  frequency     String        @default("daily")
  targetCount   Int           @default(1)
  isActive      Boolean       @default(true)
  logs          HabitLog[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model HabitLog {
  id        Int      @id @default(autoincrement())
  habitId   Int
  habit     Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)
  date      DateTime
  count     Int      @default(1)
  note      String?
  createdAt DateTime @default(now())

  @@unique([habitId, date])
}

model Resource {
  id          Int      @id @default(autoincrement())
  taskId      Int?
  task        Task?    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  title       String
  url         String?
  type        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FlashcardDeck {
  id          Int         @id @default(autoincrement())
  name        String
  description String?
  color       String      @default("#3B82F6")
  taskId      Int?
  cards       Flashcard[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Flashcard {
  id          Int           @id @default(autoincrement())
  deckId      Int
  deck        FlashcardDeck @relation(fields: [deckId], references: [id], onDelete: Cascade)
  front       String
  back        String
  nextReview  DateTime?
  interval    Int           @default(1)
  easeFactor  Float         @default(2.5)
  reviewCount Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model TaskTemplate {
  id            Int      @id @default(autoincrement())
  name          String
  description   String?
  category      String
  templateData  String   // JSON stored as string
  isPublic      Boolean  @default(false)
  useCount      Int      @default(0)
  themeId       Int?
  theme         Theme?   @relation(fields: [themeId], references: [id], onDelete: SetNull)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model DeveloperModeConfig {
  id                Int       @id @default(autoincrement())
  taskId            Int       @unique
  task              Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  isEnabled         Boolean   @default(true)
  autoApprove       Boolean   @default(false)
  notifyInApp       Boolean   @default(true)
  maxSubtasks       Int       @default(10)
  priority          String    @default("balanced")
  requireApproval   String    @default("always")
  autoExecuteOn     String    @default("[]") // JSON array stored as string
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  agentSessions     AgentSession[]
  approvalRequests  ApprovalRequest[]
}

model AgentSession {
  id                Int       @id @default(autoincrement())
  configId          Int
  config            DeveloperModeConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  status            String    @default("pending")
  startedAt         DateTime?
  completedAt       DateTime?
  lastActivityAt    DateTime  @default(now())
  totalTokensUsed   Int       @default(0)
  errorMessage      String?
  metadata          String?   // JSON stored as string
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  agentActions      AgentAction[]
  agentExecutions   AgentExecution[]
}

model AgentAction {
  id                Int       @id @default(autoincrement())
  sessionId         Int
  session           AgentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  actionType        String
  targetTaskId      Int?
  input             String?   // JSON stored as string
  output            String?   // JSON stored as string
  tokensUsed        Int       @default(0)
  durationMs        Int?
  status            String    @default("success")
  errorMessage      String?
  createdAt         DateTime  @default(now())
}

model ApprovalRequest {
  id                Int       @id @default(autoincrement())
  configId          Int
  config            DeveloperModeConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  requestType       String
  title             String
  description       String?
  proposedChanges   String    // JSON stored as string
  status            String    @default("pending")
  expiresAt         DateTime?
  approvedAt        DateTime?
  rejectedAt        DateTime?
  rejectionReason   String?
  notificationSent  Boolean   @default(false)
  executionType     String?
  estimatedChanges  String?   // JSON stored as string
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model Notification {
  id                Int       @id @default(autoincrement())
  type              String
  title             String
  message           String
  link              String?
  isRead            Boolean   @default(false)
  readAt            DateTime?
  metadata          String?   // JSON stored as string
  createdAt         DateTime  @default(now())
}

model UserSettings {
  id                      Int       @id @default(autoincrement())
  developerModeDefault    Boolean   @default(false)
  aiTaskAnalysisDefault   Boolean   @default(false)
  claudeApiKeyEncrypted   String?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
}

model AIAgentConfig {
  id              Int       @id @default(autoincrement())
  agentType       String
  name            String
  apiKeyEncrypted String?
  endpoint        String?
  modelId         String?
  isDefault       Boolean   @default(false)
  isActive        Boolean   @default(true)
  capabilities    String    @default("{}") // JSON stored as string
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  executions      AgentExecution[]
}

model AgentExecution {
  id                Int       @id @default(autoincrement())
  sessionId         Int
  session           AgentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  agentConfigId     Int?
  agentConfig       AIAgentConfig? @relation(fields: [agentConfigId], references: [id], onDelete: SetNull)
  command           String
  status            String    @default("pending")
  output            String?
  artifacts         String?   // JSON stored as string
  startedAt         DateTime?
  completedAt       DateTime?
  tokensUsed        Int       @default(0)
  executionTimeMs   Int?
  errorMessage      String?
  question          String?
  questionType      String?
  questionDetails   String?   // JSON stored as string
  claudeSessionId   String?   // Claude Code CLI session ID for --resume
  createdAt         DateTime  @default(now())
  gitCommits        GitCommit[]
}

model GitHubIntegration {
  id                Int       @id @default(autoincrement())
  repositoryUrl     String    @unique
  repositoryName    String
  ownerName         String
  accessTokenEnc    String?
  webhookSecret     String?
  isActive          Boolean   @default(true)
  syncIssues        Boolean   @default(true)
  syncPullRequests  Boolean   @default(true)
  autoLinkTasks     Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  pullRequests      GitHubPullRequest[]
  issues            GitHubIssue[]
}

model GitHubPullRequest {
  id                Int       @id @default(autoincrement())
  integrationId     Int
  integration       GitHubIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  prNumber          Int
  title             String
  body              String?
  state             String
  headBranch        String
  baseBranch        String
  authorLogin       String
  url               String
  linkedTaskId      Int?
  lastSyncedAt      DateTime
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  reviews           GitHubPRReview[]
  comments          GitHubPRComment[]
  @@unique([integrationId, prNumber])
}

model GitHubPRReview {
  id                Int       @id @default(autoincrement())
  pullRequestId     Int
  pullRequest       GitHubPullRequest @relation(fields: [pullRequestId], references: [id], onDelete: Cascade)
  reviewId          Int
  state             String
  body              String?
  authorLogin       String
  submittedAt       DateTime
  createdAt         DateTime  @default(now())
}

model GitHubPRComment {
  id                Int       @id @default(autoincrement())
  pullRequestId     Int
  pullRequest       GitHubPullRequest @relation(fields: [pullRequestId], references: [id], onDelete: Cascade)
  commentId         Int
  body              String
  path              String?
  line              Int?
  authorLogin       String
  isFromRapitas     Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model GitHubIssue {
  id                Int       @id @default(autoincrement())
  integrationId     Int
  integration       GitHubIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  issueNumber       Int
  title             String
  body              String?
  state             String
  labels            String    @default("[]") // JSON array stored as string
  authorLogin       String
  url               String
  linkedTaskId      Int?
  lastSyncedAt      DateTime
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  @@unique([integrationId, issueNumber])
}

model GitCommit {
  id                Int       @id @default(autoincrement())
  executionId       Int
  execution         AgentExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  commitHash        String
  message           String
  branch            String
  filesChanged      Int       @default(0)
  additions         Int       @default(0)
  deletions         Int       @default(0)
  createdAt         DateTime  @default(now())
}

model FavoriteDirectory {
  id          Int       @id @default(autoincrement())
  path        String    @unique
  name        String?
  isGitRepo   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model TaskPrompt {
  id                  Int       @id @default(autoincrement())
  taskId              Int
  task                Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  name                String?
  originalDescription String?
  optimizedPrompt     String
  structuredSections  String?   // JSON stored as string
  qualityScore        Int?
  isActive            Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([taskId])
}
