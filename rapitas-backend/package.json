{
  "name": "rapitas-backend",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run scripts/dev.ts",
    "dev:simple": "bun --watch index.ts",
    "dev:stable": "bun index.ts",
    "start": "bun run scripts/start.ts",
    "start:simple": "bun index.ts",
    "test": "bun test --isolate",
    "test:integration": "bun test --path-ignore-patterns=\"\" ./tests/integration/",
    "test:all": "bun test --isolate && bun test --path-ignore-patterns=\"\" ./tests/integration/",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:generate:sqlite": "bun run scripts/generate-sqlite-prisma-schema.cjs && prisma generate --schema prisma/schema.desktop",
    "db:prepare:sqlite": "bun run scripts/generate-sqlite-init-sql.cjs && prisma generate --schema prisma/schema.desktop",
    "db:migrate:desktop": "bun run scripts/migrate-postgres-to-sqlite.ts",
    "db:studio": "prisma studio",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.ts\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.ts\" --ignore-path .gitignore"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/bun": "^1.3.13",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "eslint": "^10.3.0",
    "prettier": "^3.8.3",
    "prisma": "^6.19.3",
    "sharp": "^0.34.5"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "@elysiajs/cors": "^1.4.2",
    "@elysiajs/swagger": "^1.3.1",
    "@google/generative-ai": "^0.24.1",
    "@napi-rs/keyring": "^1.3.0",
    "@prisma/client": "^6.19.3",
    "@sentry/bun": "^10.51.0",
    "@sinclair/typebox": "0.34.15",
    "@types/ws": "^8.18.1",
    "@xenova/transformers": "^2.17.2",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "elysia": "^1.4.28",
    "googleapis": "^171.4.0",
    "ioredis": "^5.10.1",
    "lru-cache": "^11.3.5",
    "openai": "^6.35.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "playwright": "^1.59.1",
    "ts-fsrs": "^5.3.2",
    "ws": "^8.20.0"
  },
  "trustedDependencies": [
    "protobufjs"
  ],
  "overrides": {
    "protobufjs": "^7.5.5",
    "defu": "^6.1.5",
    "minimatch": "^9.0.7",
    "flatted": "^3.4.0",
    "picomatch": "^4.0.4"
  }
}
