{
  "name": "rapitas-backend",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run scripts/dev.ts",
    "dev:simple": "bun --watch index.ts",
    "dev:web": "node scripts/switch-schema.cjs postgres && prisma generate && bun --watch index.ts",
    "dev:tauri": "node scripts/switch-schema.cjs sqlite && prisma generate && bun --watch index.ts",
    "start": "bun index.ts",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "schema:postgres": "node scripts/switch-schema.cjs postgres",
    "schema:sqlite": "node scripts/switch-schema.cjs sqlite",
    "schema:status": "node scripts/switch-schema.cjs status"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "prisma": "^6.19.0"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "@elysiajs/cors": "^1.4.0",
    "@prisma/client": "^6.19.0",
    "dotenv": "^17.2.3",
    "elysia": "^1.4.15"
  }
}
