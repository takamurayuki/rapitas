{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "lib": ["ES2020"],
    "typeRoots": ["./node_modules/@types", "./@types"],
    "types": []
  },
  "exclude": ["node_modules/**/*", "**/*.d.ts", "global.d.ts", "tests/**/*"],
  "include": ["**/*.ts", "**/*.tsx"]
}
