{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "node",
    "lib": ["ES2020"],
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "strictFunctionTypes": false,
    "strictBindCallApply": false,
    "strictPropertyInitialization": false,
    "noImplicitThis": false,
    "alwaysStrict": false,
    "noEmit": true,
    "typeRoots": ["./node_modules/@types", "./@types"],
    "types": []
  },
  "exclude": [
    "node_modules/**/*",
    "**/*.d.ts",
    "global.d.ts",
    "node_modules/@elysiajs/websocket/**/*",
    "node_modules/@elysiajs/websocket/src/**/*",
    "node_modules/@elysiajs/websocket/src/index.ts",
    "node_modules/@elysiajs/websocket/src/types.ts"
  ],
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ]
}
