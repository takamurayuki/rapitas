# ============================================
# Rapitas Backend - Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ---- Server ----
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000,tauri://localhost
FRONTEND_URL=http://localhost:3000

# ---- Database ----
DATABASE_URL=postgresql://user:password@localhost:5432/rapitas

# ---- Encryption ----
# Used for encrypting sensitive data (API keys in DB)
# Optional: If not set, a key will be auto-generated and saved to .encryption-key file
# To manually set: node -e "console.log(crypto.randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# ---- Admin ----
# Required in production for /agents/shutdown, /agents/restart, /agents/diagnose
# Generate: node -e "console.log(crypto.randomBytes(16).toString('hex'))"
ADMIN_SECRET=

# ---- AI Providers (optional, can be set via UI) ----
CLAUDE_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=

# ---- CLI Tool Paths (optional) ----
CLAUDE_CODE_PATH=claude
GEMINI_CLI_PATH=gemini
CODEX_CLI_PATH=codex

# ---- Google OAuth (optional) ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# ---- File Storage ----
UPLOAD_DIR=uploads
